# Local development defaults. Copy to .env and replace the password before
# using this configuration outside a local development environment.
POSTGRES_DB=bastion
POSTGRES_USER=bastion
POSTGRES_PASSWORD=bastion_dev_password_change_me
POSTGRES_PORT=5432

VALKEY_PORT=6380
OLLAMA_PORT=11434

# Bastion.Gate local runtime defaults
DATABASE_URL=postgresql+asyncpg://bastion:bastion_dev_password_change_me@localhost:5432/bastion
OLLAMA_BASE_URL=http://localhost:11434
GATE_PORT=8000
OLLAMA_TIMEOUT_SECONDS=120

# Hugging Face read-scoped token with access to the gated Llama Prompt Guard 2 model.
HF_TOKEN=

# SampleBank Copilot local runtime defaults
GATE_BASE_URL=http://localhost:8000
SAMPLE_TARGET_PORT=8080
SAMPLE_TARGET_MODEL=llama3.1:8b

# Bastion.Strike local runtime defaults. DATABASE_URL above is shared with Gate.
STRIKE_REQUEST_TIMEOUT_SECONDS=60
VALKEY_URL=redis://localhost:6380/0
EMBEDDING_MODEL=nomic-embed-text

# Bastion.Control local runtime default
CONTROL_PORT=5080
