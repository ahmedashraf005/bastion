# Local development defaults. Copy to .env and replace the password before
# using this configuration outside a local development environment.
POSTGRES_DB=bastion
POSTGRES_USER=bastion
POSTGRES_PASSWORD=bastion_dev_password_change_me
POSTGRES_PORT=5432

VALKEY_PORT=6379
OLLAMA_PORT=11434

# Bastion.Gate local runtime defaults
DATABASE_URL=postgresql+asyncpg://bastion:bastion_dev_password_change_me@localhost:5432/bastion
OLLAMA_BASE_URL=http://localhost:11434
GATE_PORT=8000
OLLAMA_TIMEOUT_SECONDS=120
